# =============================================================================
# QB Expense Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Server ---
PORT=3000
NODE_ENV=development

# --- QuickBooks OAuth 2.0 ---
# Get these from https://developer.intuit.com → Your App → Keys & Credentials
QB_CLIENT_ID=your_client_id_here
QB_CLIENT_SECRET=your_client_secret_here
QB_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Sandbox (development) or Production
# Sandbox: https://sandbox-quickbooks.api.intuit.com
# Production: https://quickbooks.api.intuit.com
QB_API_BASE_URL=https://sandbox-quickbooks.api.intuit.com
QB_ENVIRONMENT=sandbox

# Your QuickBooks Company ID (obtained after OAuth authorization)
# You'll get this automatically during the OAuth flow
QB_COMPANY_ID=

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# --- Email Ingestion ---
# Option A: IMAP (poll an inbox)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=expenses@performancelabs.ai
EMAIL_IMAP_PASSWORD=your_app_password_here

# Option B: Postmark Inbound Webhook (recommended for production)
# POSTMARK_INBOUND_ADDRESS=expenses@inbound.performancelabs.ai
# POSTMARK_WEBHOOK_SECRET=your_webhook_secret

# --- Redis (for job queue) ---
REDIS_URL=redis://localhost:6379

# --- Database ---
DATABASE_URL=sqlite:./data/expense-agent.db
# For production: postgres://user:pass@host:5432/expense_agent

# --- Security ---
# Used to encrypt stored OAuth tokens at rest
ENCRYPTION_KEY=generate_a_32_byte_hex_key_here
SESSION_SECRET=generate_a_random_session_secret

# JWT authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_64_byte_hex_key_here
JWT_EXPIRY=8h

# CORS — comma-separated list of allowed origins (empty = allow all in dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Logging ---
LOG_LEVEL=debug
